{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "categories": {
        "correctness": "error",
        "suspicious": "warn",
        "perf": "warn"
    },
    "rules": {
        "no-unused-vars": "error",
        "eqeqeq": "error",
        "no-var": "error",
        "prefer-const": "error",
        "no-throw-literal": "error",
        "no-promise-executor-return": "error"
    },
    "ignorePatterns": [
        "dist/",
        "node_modules/",
        "src/shared/database/generated/"
    ]
}
