{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "singleQuote": false,
    "printWidth": 80,
    "tabWidth": 4,
    "semi": true,
    "useTabs": false,
    "arrowParens": "always",
    "bracketSameLine": true,
    "sortPackageJson": false,
    "ignorePatterns": [
        "node_modules/",
        "package-lock.json",
        "*.md",
        ".git",
        "*.min.js",
        "generated/"
    ],
    "sortImports": true
}
